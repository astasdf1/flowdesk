{
  "name": "flowdesk",
  "version": "0.0.0",
  "private": true,
  "description": "FlowDesk for opencode workspace scaffold.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/opencode-plugin",
    "typecheck": "tsc -b packages/core packages/opencode-plugin --pretty false",
    "test": "npm run test:functional",
    "test:functional": "npm run build && node scripts/run-tests.mjs --mode functional",
    "test:slow": "npm run build && node scripts/run-tests.mjs --mode slow",
    "test:integration": "npm run build && node scripts/run-tests.mjs --mode integration",
    "test:full": "npm run build && node scripts/run-tests.mjs --mode full",
    "models:list": "opencode models",
    "models:refresh": "node scripts/refresh-opencode-model-availability.mjs && node scripts/export-model-availability-db.mjs"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.15.6",
    "@opentui/core": "^0.2.16",
    "@opentui/keymap": "^0.2.16",
    "@opentui/solid": "^0.2.16",
    "@types/node": "24.10.1",
    "solid-js": "^1.9.13",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.14.1",
    "npm": ">=11.11.0"
  }
}
