{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": ["./.tools/codegraph/node_modules/.bin/codegraph", "serve", "--mcp", "--path", "."],
      "enabled": true,
      "timeout": 10000
    }
  },
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": {
      "*": "allow"
    }
  }
}
