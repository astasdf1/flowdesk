{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/solid",
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "references": [
