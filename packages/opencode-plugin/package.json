{
  "name": "@flowdesk/opencode-plugin",
  "version": "0.0.0",
  "private": true,
  "description": "FlowDesk OpenCode plugin scaffold without production dispatch registration.",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run build && node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@flowdesk/core": "^0.0.0",
    "@opencode-ai/plugin": "1.3.12"
  }
}
