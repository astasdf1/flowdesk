{
  "name": "@flowdesk/opencode-plugin",
  "version": "0.1.6",
  "description": "FlowDesk OpenCode plugin with Release 1 non-dispatch command-backed registration.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astasdf1/flowdesk.git",
    "directory": "packages/opencode-plugin"
  },
  "homepage": "https://github.com/astasdf1/flowdesk#readme",
  "bugs": {
    "url": "https://github.com/astasdf1/flowdesk/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./bootstrap-cli": {
      "types": "./dist/bootstrap-cli.d.ts",
      "import": "./dist/bootstrap-cli.js",
      "default": "./dist/bootstrap-cli.js"
    }
  },
  "bin": {
    "flowdesk-install-release1": "dist/bootstrap-cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run build && node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@flowdesk/core": "^0.1.6"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.40 <2"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": false
    }
  }
}
