{
  "name": "@flowdesk/opencode-plugin",
  "version": "0.3.0",
  "description": "FlowDesk OpenCode plugin with Release 1 non-dispatch command-backed registration.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astasdf1/flowdesk.git",
    "directory": "packages/opencode-plugin"
  },
  "homepage": "https://github.com/astasdf1/flowdesk#readme",
  "bugs": {
    "url": "https://github.com/astasdf1/flowdesk/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/.tsbuildinfo",
    "data/model-availability.db",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js",
      "default": "./dist/tui.js"
    },
    "./bootstrap-cli": {
      "types": "./dist/bootstrap-cli.d.ts",
      "import": "./dist/bootstrap-cli.js",
      "default": "./dist/bootstrap-cli.js"
    }
  },
  "bin": {
    "flowdesk-install-release1": "dist/bootstrap-cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run test:functional",
    "test:functional": "npm run build && node ../../scripts/run-tests.mjs --mode functional --package opencode-plugin",
    "test:slow": "npm run build && node ../../scripts/run-tests.mjs --mode slow --package opencode-plugin",
    "test:integration": "npm run build && node ../../scripts/run-tests.mjs --mode integration --package opencode-plugin",
    "test:full": "npm run build && node ../../scripts/run-tests.mjs --mode full --package opencode-plugin"
  },
  "dependencies": {
    "@flowdesk/core": "^0.3.0"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.14.40 <2",
    "@opentui/core": ">=0.2.15",
    "@opentui/keymap": ">=0.2.15",
    "@opentui/solid": ">=0.2.15"
  },
  "peerDependenciesMeta": {
    "@opencode-ai/plugin": {
      "optional": false
    }
  }
}
