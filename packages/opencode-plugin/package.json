{
  "name": "@flowdesk/opencode-plugin",
  "version": "0.0.0",
  "private": true,
  "description": "FlowDesk OpenCode plugin with Release 1 non-dispatch command-backed registration.",
  "type": "module",
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/.tsbuildinfo"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./bootstrap-cli": {
      "types": "./dist/bootstrap-cli.d.ts",
      "import": "./dist/bootstrap-cli.js",
      "default": "./dist/bootstrap-cli.js"
    }
  },
  "bin": {
    "flowdesk-install-release1": "./dist/bootstrap-cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run build && node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@flowdesk/core": "^0.0.0",
    "@opencode-ai/plugin": "1.3.12"
  }
}
