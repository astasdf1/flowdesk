{
  "name": "@flowdesk/core",
  "version": "0.2.1",
  "description": "Core FlowDesk contracts and Release 1 boundaries.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/astasdf1/flowdesk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/astasdf1/flowdesk#readme",
  "bugs": {
    "url": "https://github.com/astasdf1/flowdesk/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "!dist/**/*.test.d.ts",
    "!dist/**/*.test.d.ts.map",
    "!dist/**/*.test.js",
    "!dist/**/*.test.js.map",
    "!dist/.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "flowdesk-omnigent-usage-snapshot": "dist/omnigent-usage-snapshot-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./omnigent-usage-snapshot-cli": {
      "types": "./dist/omnigent-usage-snapshot-cli.d.ts",
      "default": "./dist/omnigent-usage-snapshot-cli.js"
    },
    "./omnigent-selection-cli": {
      "types": "./dist/omnigent-selection-cli.d.ts",
      "default": "./dist/omnigent-selection-cli.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "npm run test:functional",
    "test:functional": "npm run build && node ../../scripts/run-tests.mjs --mode functional --package core",
    "test:slow": "npm run build && node ../../scripts/run-tests.mjs --mode slow --package core",
    "test:integration": "npm run build && node ../../scripts/run-tests.mjs --mode integration --package core",
    "test:full": "npm run build && node ../../scripts/run-tests.mjs --mode full --package core"
  }
}
